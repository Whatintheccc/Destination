  "instrument_epoch": "p13-product-2026-07-10-v1",
  "evidence_record_schema_version": "dogfood_evidence.v1",
  "status_semantics": {
    "pass": "predicate satisfied by complete evidence",
    "fail": "evidence contradicts the contract",
