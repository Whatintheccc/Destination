  "scenarios": [
    {"scenario_id": "P-IDENTITY", "order": 1, "cells": ["D0", "D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "identity", "stimulus": "Launch the exact app with a fresh run directory.", "effect_ceiling": "none", "required_sources": ["run_manifest", "launch_state_before", "health", "process_snapshot_before"]},
    {"scenario_id": "P-OBSERVE", "order": 2, "cells": ["D1", "D2", "D3", "D4", "D5", "D6"], "predicate_id": "observe", "stimulus": "What do you know about my calendar tomorrow? Cite the events or gaps used.", "effect_ceiling": "recommendation_only", "required_sources": ["operator_truth", "provider_read", "rendered_view", "replay"]},
    {"scenario_id": "P-RECOMMEND", "order": 3, "cells": ["D1", "D2", "D3", "D4", "D5", "D6"], "predicate_id": "recommend", "stimulus": "Suggest the single highest-value change. Explain why, including no-op, but only recommend it; do not stage or change my calendar.", "effect_ceiling": "recommendation_only", "required_sources": ["rendered_view", "replay"]},
    {"scenario_id": "P-ACTION-VISIBLE", "order": 4, "cells": ["D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "action_visible", "stimulus": "Inspect the leading candidate before opening debug UI.", "effect_ceiling": "recommendation_only", "required_sources": ["rendered_view", "replay", "screenshot"]},
    {"scenario_id": "P-TIMEZONE", "order": 5, "cells": ["D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "timezone", "stimulus": "Evaluate the bound near-midnight and DST fixtures in the bound user timezone.", "effect_ceiling": "recommendation_only", "required_sources": ["operator_truth", "rendered_view", "replay"]},
    {"scenario_id": "P-FOLLOWUP", "order": 6, "cells": ["D1", "D2", "D3", "D4", "D5", "D6"], "predicate_id": "followup", "stimulus": "What exact time and duration are you proposing? Do not replan.", "effect_ceiling": "recommendation_only", "required_sources": ["rendered_view", "replay"]},
    {"scenario_id": "P-CORRECTION", "order": 7, "cells": ["D1", "D2", "D3", "D4", "D5", "D6"], "predicate_id": "correction", "stimulus": "Correct one cited assumption, then ask for the recommendation again.", "effect_ceiling": "recommendation_only", "required_sources": ["ui_action", "rendered_view", "replay"]},
    {"scenario_id": "P-SIMULATE", "order": 8, "cells": ["D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "simulate", "stimulus": "Explicitly select Simulate.", "effect_ceiling": "simulation_only", "required_sources": ["ui_action", "rendered_view", "replay"]},
    {"scenario_id": "P-NOOP", "order": 9, "cells": ["D1", "D2", "D3", "D4", "D5", "D6"], "predicate_id": "noop", "stimulus": "Use the fixture where every calendar change is dominated.", "effect_ceiling": "recommendation_only", "required_sources": ["operator_truth", "rendered_view", "replay"]},
    {"scenario_id": "P-DENIAL", "order": 10, "cells": ["D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "denial", "stimulus": "Request the bound out-of-scope or conflicted action.", "effect_ceiling": "denial_only", "required_sources": ["rendered_view", "replay"]},
    {"scenario_id": "P-FEEDBACK", "order": 11, "cells": ["D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "feedback", "stimulus": "Mark the rendered candidate useful, dismissed, or corrected.", "effect_ceiling": "feedback_only", "required_sources": ["ui_action", "rendered_view", "replay"]},
    {"scenario_id": "P-RESTART", "order": 12, "cells": ["D1", "D2", "D3", "D4", "D5", "D6", "D7"], "predicate_id": "restart", "stimulus": "Quit after feedback and relaunch the same run.", "effect_ceiling": "restore_only", "required_sources": ["launch_state_after", "rendered_view", "replay"]},
    {"scenario_id": "P-LIVE-READ", "order": 13, "cells": ["D5", "D6", "D7"], "predicate_id": "live_read", "stimulus": "Compare the bounded real-calendar window with operator truth.", "effect_ceiling": "real_read_only", "required_sources": ["operator_truth", "provider_read", "rendered_view"]},
    {"scenario_id": "P-EFFECT", "order": 14, "cells": ["D7"], "predicate_id": "effect", "stimulus": "Explicitly confirm one attendee-free private prep block.", "effect_ceiling": "one_private_create", "required_sources": ["ui_action", "replay", "provider_after"]},
    {"scenario_id": "P-UNDO", "order": 15, "cells": ["D7"], "predicate_id": "undo", "stimulus": "Request undo, verify provider absence, then restart.", "effect_ceiling": "one_compensation", "required_sources": ["ui_action", "replay", "provider_after_undo", "launch_state_after"]}
