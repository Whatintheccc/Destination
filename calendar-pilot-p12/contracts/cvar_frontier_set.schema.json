{
  "$id": "https://calendar-pilot.local/contracts/cvar_frontier_set.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CVarFrontierSetV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cvar_frontier_set_schema_version", "generated_at", "role", "producer",
    "source_revision", "tuning", "seed_set", "rows", "content_sha256"
  ],
  "properties": {
    "cvar_frontier_set_schema_version": {"const": "cvar_frontier_set.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "role": {"enum": ["before", "after"]},
    "producer": {"type": "object", "required": ["producer_id", "bound_command"]},
    "source_revision": {"type": "object", "required": ["git_sha", "clean", "source_sha256"]},
    "tuning": {"type": "object", "required": ["policy_tuning_path", "policy_tuning_sha256"]},
    "seed_set": {"type": "object", "required": ["seed_set_id", "path", "sha256"]},
    "rows": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["seed_id", "seed_sha256", "frontier", "frontier_sha256"]}},
    "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
