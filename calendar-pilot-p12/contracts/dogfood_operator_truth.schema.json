{
  "$id": "https://calendar-pilot.local/contracts/dogfood_operator_truth.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DogfoodOperatorTruthV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["dogfood_operator_truth_schema_version", "run_id", "created_at", "timezone", "redaction_class", "provider_identity", "facts"],
  "properties": {
    "dogfood_operator_truth_schema_version": {"const": "dogfood_operator_truth.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "timezone": {"type": "string", "minLength": 1},
    "redaction_class": {"enum": ["fixture", "scenario_minimal", "sensitive_local_only"]},
    "provider_identity": {"type": "string", "minLength": 1},
    "facts": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false,
        "required": ["fact_id", "kind", "value", "source_hash"],
        "properties": {"fact_id": {"type": "string", "minLength": 1}, "kind": {"type": "string", "minLength": 1}, "value": {"type": "object"}, "source_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
      }
    }
  }
}
