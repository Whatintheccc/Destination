{
  "$id": "https://calendar-pilot.local/contracts/reward_head_report_v3.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RewardHeadReportV3",
  "type": "object",
  "additionalProperties": false,
  "required": ["reward_head_report_schema_version", "reward_head_deltas", "reward_evidence", "gates", "hold_reasons", "decision"],
  "properties": {
    "reward_head_report_schema_version": {"const": "reward_head_report.v3"},
    "reward_head_deltas": {"type": "object"},
    "reward_evidence": {
      "type": "object",
      "required": ["consumed_reward_rows", "occurrence_ids_unique", "declared_source_classification", "source_shape_required"],
      "properties": {
        "consumed_reward_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["occurrence_id", "record_id", "source_artifact_sha256", "source_line_no", "provenance", "source_class", "source_shape_valid"]
          }
        },
        "occurrence_ids_unique": {"const": true},
        "declared_source_classification": {
          "type": "object",
          "required": ["human_occurrence_ids", "simulator_occurrence_ids", "invalid_source_shape_occurrence_ids", "direct_simulator_positive_credit"]
        },
        "source_shape_required": {"const": true}
      }
    },
    "gates": {"type": "object", "required": ["reward_purity", "occurrence_identity_unique", "declared_source_shape", "direct_simulator_credit_screen"]},
    "hold_reasons": {"type": "array"},
    "decision": {"enum": ["pass", "hold", "fail"]}
  }
}
