{
  "$id": "https://calendar-pilot.local/contracts/b_migrate_report_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BMigrateReportV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "b_migrate_report_schema_version", "decision", "manifest_id", "producer_commands",
    "before_artifact", "after_artifact", "assertion_set", "assertions", "failures"
  ],
  "properties": {
    "b_migrate_report_schema_version": {"const": "b_migrate_report.v2"},
    "decision": {"enum": ["pass", "hold", "fail"]},
    "manifest_id": {"type": "string"},
    "producer_commands": {"type": "object", "required": ["old", "new"]},
    "before_artifact": {"type": "object", "required": ["path", "sha256", "content_sha256"]},
    "after_artifact": {"type": "object", "required": ["path", "sha256", "content_sha256"]},
    "assertion_set": {"type": "object", "required": ["path", "sha256", "assertion_set_id"]},
    "assertions": {"type": "array", "minItems": 1},
    "failures": {"type": "array"}
  }
}
