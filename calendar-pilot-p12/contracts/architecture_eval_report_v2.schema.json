{
  "$id": "https://calendar-pilot.local/contracts/architecture_eval_report_v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchitectureEvalReportV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "architecture_eval_report_schema_version", "run_id", "generated_at", "decision",
    "repository", "instrument_artifacts", "report_paths", "execution", "scenario_set",
    "binding", "artifact_root", "rails", "scenarios"
  ],
  "properties": {
    "architecture_eval_report_schema_version": {"const": "architecture_eval_report.v2"},
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "decision": {"enum": ["pass", "fail", "hold"]},
    "repository": {"type": "object"},
    "instrument_artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "report_paths": {"type": "object"},
    "execution": {"type": "object"},
    "scenario_set": {"type": "object"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "verification", "required_scenario_ids"],
      "properties": {
        "manifest": {"$ref": "#/$defs/artifact"},
        "verification": {"$ref": "#/$defs/artifact"},
        "required_scenario_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "artifact_root": {"type": "string"},
    "rails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preservation", "target_conformance"],
      "properties": {
        "preservation": {"$ref": "#/$defs/rail"},
        "target_conformance": {"$ref": "#/$defs/rail"}
      }
    },
    "scenarios": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/scenario"}}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": {"type": "string"},
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "rail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "scenario_count", "status_counts", "blocking_scenario_ids", "unmet_scenario_ids"],
      "properties": {
        "decision": {"enum": ["pass", "fail", "hold", "not_reached"]},
        "scenario_count": {"type": "integer", "minimum": 0},
        "status_counts": {"type": "object"},
        "blocking_scenario_ids": {"type": "array", "items": {"type": "string"}},
        "unmet_scenario_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id", "rail", "gate_mode", "category", "adapter_case", "predicate_id",
        "binding_trigger", "status", "summary", "observable_vector", "predicate_evidence", "artifacts"
      ],
      "properties": {
        "scenario_id": {"type": "string"},
        "rail": {"enum": ["preservation", "target_conformance"]},
        "gate_mode": {"enum": ["required", "observe"]},
        "category": {"type": "string"},
        "adapter_case": {"type": "string"},
        "predicate_id": {"type": "string"},
        "binding_trigger": {"type": "string"},
        "status": {"enum": ["pass", "fail", "hold", "not_reached"]},
        "summary": {"type": "string"},
        "observable_vector": {"type": "object"},
        "predicate_evidence": {"type": "object"},
        "artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}
      }
    }
  }
}
