{
  "$id": "https://calendar-pilot.local/contracts/p13_instrument_bundle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "P13InstrumentBundleV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "p13_instrument_bundle_schema_version", "instrument_epoch", "repository",
    "verification_root", "toolchain", "artifacts", "bundle_sha256"
  ],
  "properties": {
    "p13_instrument_bundle_schema_version": {"const": "p13_instrument_bundle.v1"},
    "instrument_epoch": {"type": "string", "minLength": 1},
    "repository": {"type": "object"},
    "verification_root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "public_key_sha256"],
      "properties": {
        "algorithm": {"const": "rsa-sha256"},
        "public_key_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "toolchain": {"type": "object"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256", "size_bytes"],
        "properties": {
          "kind": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
