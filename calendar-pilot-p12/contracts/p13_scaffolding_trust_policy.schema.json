{
  "$id": "https://calendar-pilot.local/contracts/p13_scaffolding_trust_policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "P13ScaffoldingTrustPolicyV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scaffolding_trust_policy_schema_version",
    "mode",
    "policy_id",
    "policy_epoch",
    "repository_origin_id",
    "valid_from",
    "expires_at",
    "roles",
    "protected_candidate_principals",
    "revoked_key_ids"
  ],
  "properties": {
    "scaffolding_trust_policy_schema_version": {"const": "p13_scaffolding_trust_policy.v1"},
    "mode": {"const": "scaffold_only"},
    "policy_id": {"$ref": "#/$defs/id"},
    "policy_epoch": {"type": "integer", "minimum": 1},
    "repository_origin_id": {"$ref": "#/$defs/id"},
    "valid_from": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_authorizer", "isolated_evaluator", "independent_tcb_reviewer"],
      "properties": {
        "operator_authorizer": {"$ref": "#/$defs/role"},
        "isolated_evaluator": {"$ref": "#/$defs/role"},
        "independent_tcb_reviewer": {"$ref": "#/$defs/role"}
      }
    },
    "protected_candidate_principals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "revoked_key_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "key_id",
        "algorithm",
        "spki_der_base64",
        "public_key_sha256",
        "not_before",
        "not_after"
      ],
      "properties": {
        "principal_id": {"$ref": "#/$defs/id"},
        "key_id": {"$ref": "#/$defs/id"},
        "algorithm": {"const": "rsa-sha256"},
        "spki_der_base64": {"type": "string", "pattern": "^[A-Za-z0-9+/]+={0,2}$"},
        "public_key_sha256": {"$ref": "#/$defs/sha256"},
        "not_before": {"type": "string", "format": "date-time"},
        "not_after": {"type": "string", "format": "date-time"}
      }
    }
  }
}
