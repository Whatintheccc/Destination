{
  "$id": "https://calendar-pilot.local/contracts/reward_ingress_ledger.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RewardIngressLedgerV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["reward_ingress_ledger_schema_version", "issuer_registry", "events"],
  "properties": {
    "reward_ingress_ledger_schema_version": {"const": "reward_ingress_ledger.v1"},
    "issuer_registry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issuer_id", "source_class", "public_key_path", "public_key_sha256"],
        "properties": {
          "issuer_id": {"type": "string", "minLength": 1},
          "source_class": {"enum": ["human", "simulator", "synthetic"]},
          "public_key_path": {"type": "string", "minLength": 1},
          "public_key_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issuer_id", "event_id", "global_occurrence_id", "observed_at", "program", "parent_occurrence_ids", "utility_credit", "payload_sha256", "signature"],
        "properties": {
          "issuer_id": {"type": "string", "minLength": 1},
          "event_id": {"type": "string", "minLength": 1},
          "global_occurrence_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "observed_at": {"type": "string", "format": "date-time"},
          "program": {"enum": ["program_a_human_utility", "failure_detector", "search_only"]},
          "parent_occurrence_ids": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "uniqueItems": true},
          "utility_credit": {"type": "number"},
          "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "signature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["algorithm", "value_base64"],
            "properties": {
              "algorithm": {"const": "rsa-sha256"},
              "value_base64": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
