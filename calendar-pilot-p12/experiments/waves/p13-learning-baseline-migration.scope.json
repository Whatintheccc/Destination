{
  "wave_scope_schema_version": "p13_wave_scope.v1",
  "declared_paths": [
    "calendar-pilot-p12/README.md",
    "calendar-pilot-p12/experiments/learning/**",
    "calendar-pilot-p12/experiments/promoted/CURRENT.json",
    "calendar-pilot-p12/experiments/waves/p13-learning-baseline-migration.scope.json",
    "compression-roadmap.md"
  ],
  "declared": {
    "actions": [],
    "backends": [],
    "surfaces": ["architecture_docs", "docs", "unowned", "wave_scope"],
    "instruments": ["access_point_docs", "architecture_spec", "binding_manifest"],
    "control_planes": ["evaluator"]
  },
  "required_scenarios": [
    "preservation.action_reward",
    "preservation.authority_belief_denial",
    "preservation.expired_authority",
    "preservation.explanation_trace",
    "preservation.frontier_normal",
    "preservation.frontier_timeout",
    "preservation.missing_belief_evidence",
    "preservation.provider_commit",
    "preservation.provider_conflict",
    "preservation.provider_rollback",
    "preservation.restart_restore",
    "target.binding_manifest_affectedness",
    "target.binding_manifest_protected_path_rejection",
    "target.binding_manifest_signature",
    "target.holdout_non_exposure",
    "target.instrument_mutation_rejection",
    "target.optimizer_write_boundary",
    "target.promotion_override_rejection",
    "target.reward_identity_provenance",
    "target.signed_policy_promotion"
  ],
  "old_producer": {
    "cvar": {"producer_id": "cvar.before.learning-current", "command": ["python3", "scripts/produce_cvar_frontier.py", "--role", "before", "--current", "experiments/promoted/CURRENT.json"]},
    "b_migrate": {"producer_id": "b_migrate.old.frontend_snapshot", "command": ["python3", "scripts/produce_b_migrate_old.py"]}
  },
  "new_producer": {
    "cvar": {"producer_id": "cvar.after.learning-current", "command": ["python3", "scripts/produce_cvar_frontier.py", "--role", "after", "--current", "experiments/promoted/CURRENT.json"]},
    "b_migrate": {"producer_id": "b_migrate.new.frontend_projector", "command": ["python3", "scripts/produce_b_migrate_new.py"]}
  },
  "live_legs": []
}
