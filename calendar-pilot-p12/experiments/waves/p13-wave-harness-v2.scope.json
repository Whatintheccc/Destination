{
  "wave_scope_schema_version": "p13_wave_scope.v1",
  "declared_paths": [
    ".github/workflows/p13-ruler.yml",
    "Makefile",
    "compression-roadmap.md",
    "calendar-pilot-p12/Makefile",
    "calendar-pilot-p12/README.md",
    "calendar-pilot-p12/configs/p13_instrument_artifacts.json",
    "calendar-pilot-p12/configs/p13_ownership_map.json",
    "calendar-pilot-p12/contracts/**",
    "calendar-pilot-p12/evals/p13_ruler/**",
    "calendar-pilot-p12/experiments/configs/**",
    "calendar-pilot-p12/experiments/root_lists/**",
    "calendar-pilot-p12/experiments/templates/**",
    "calendar-pilot-p12/scripts/make_experiment_record.py",
    "calendar-pilot-p12/scripts/make_reward_head_report.py",
    "calendar-pilot-p12/scripts/produce_b_migrate_new.py",
    "calendar-pilot-p12/scripts/produce_b_migrate_old.py",
    "calendar-pilot-p12/scripts/produce_cvar_frontier.py",
    "calendar-pilot-p12/scripts/run_b_migrate_dual_run_v2.py",
    "calendar-pilot-p12/scripts/run_cvar_report_v2.py",
    "calendar-pilot-p12/scripts/run_p13_wave_gate.py",
    "calendar-pilot-p12/tests/**"
  ],
  "declared": {
    "actions": ["*"],
    "backends": ["*"],
    "surfaces": [
      "app_access",
      "architecture_docs",
      "configuration",
      "contracts",
      "docs",
      "evaluation",
      "experiment_configuration",
      "experiment_record",
      "ruler_scripts",
      "tests",
      "unowned",
      "workspace_access"
    ],
    "instruments": [
      "access_point_docs",
      "architecture_eval",
      "architecture_spec",
      "configuration",
      "contract_schemas",
      "experiment_configuration",
      "experiment_record",
      "release_and_wave_ruler",
      "root_ci",
      "tests",
      "wave_gate"
    ],
    "control_planes": ["effect_tcb", "evaluator", "optimizer"]
  },
  "required_scenarios": [
    "preservation.action_reward",
    "preservation.authority_belief_denial",
    "preservation.expired_authority",
    "preservation.explanation_trace",
    "preservation.frontier_normal",
    "preservation.frontier_timeout",
    "preservation.missing_belief_evidence",
    "preservation.provider_commit",
    "preservation.provider_conflict",
    "preservation.provider_rollback",
    "preservation.restart_restore",
    "target.binding_manifest_affectedness",
    "target.binding_manifest_signature",
    "target.instrument_mutation_rejection",
    "target.optimizer_write_boundary"
  ],
  "old_producer": {
    "cvar": {
      "producer_id": "cvar.before.current",
      "command": [
        "python3",
        "scripts/produce_cvar_frontier.py",
        "--role",
        "before",
        "--current",
        "experiments/promoted/CURRENT.json"
      ]
    },
    "b_migrate": {
      "producer_id": "b_migrate.old.session_snapshot",
      "command": ["python3", "scripts/produce_b_migrate_old.py"]
    }
  },
  "new_producer": {
    "cvar": {
      "producer_id": "cvar.after.current",
      "command": [
        "python3",
        "scripts/produce_cvar_frontier.py",
        "--role",
        "after",
        "--current",
        "experiments/promoted/CURRENT.json"
      ]
    },
    "b_migrate": {
      "producer_id": "b_migrate.new.frontend_projector",
      "command": ["python3", "scripts/produce_b_migrate_new.py"]
    }
  },
  "live_legs": []
}
