  },
  "new_producer": {
    "cvar": {"producer_id": "cvar.after.current", "command": ["python3", "scripts/produce_cvar_frontier.py", "--role", "after", "--current", "experiments/promoted/CURRENT.json"]},
    "b_migrate": {"producer_id": "b_migrate.new.frontend_projector", "command": ["python3", "scripts/produce_b_migrate_new.py"]}
  },
