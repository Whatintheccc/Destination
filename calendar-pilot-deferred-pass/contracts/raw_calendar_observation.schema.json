

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calendar-pilot.local/contracts/raw_calendar_observation.schema.json",
  "title": "RawCalendarObservationV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["observation_id", "user_scope_id", "observed_at", "time_zone_id", "events"],
  "properties": {
    "observation_id": {"type": "string"},
    "user_scope_id": {"type": "string"},
    "observed_at": {"type": "string", "format": "date-time"},
    "time_zone_id": {"type": "string"},
    "events": {"type": "array", "items": {"$ref": "#/$defs/raw_calendar_event"}},
    "tasks": {"type": "array", "items": {"$ref": "#/$defs/raw_task"}},
    "device_context": {"$ref": "#/$defs/device_context"},
    "notification_history": {"type": "array", "items": {"type": "object"}},
    "prior_actions": {"type": "array", "items": {"type": "object"}}
  },
  "$defs": {
    "raw_calendar_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "title", "start", "end"],
      "properties": {
        "event_id": {"type": "string"},
        "title": {"type": "string"},
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"},
        "calendar_id": {"type": "string"},
        "attendees": {"type": "array", "items": {"type": "string"}},
        "location": {"type": "string"},
        "notes": {"type": "string"},
        "is_user_owned": {"type": "boolean"},
        "is_flexible": {"type": "boolean"},
        "category": {"type": "string"}
      }
    },
    "raw_task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "title", "estimated_minutes"],
      "properties": {
        "task_id": {"type": "string"},
        "title": {"type": "string"},
        "due": {"type": ["string", "null"], "format": "date-time"},
        "estimated_minutes": {"type": "integer"},
        "category": {"type": "string"}
      }
    },
    "device_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local_hour": {"type": "integer"},
        "active_surface": {"type": "string"},
        "is_focus_mode": {"type": "boolean"}
      }
    }
  }
}
